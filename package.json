{
  "name": "dataverse-tools",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build -ws",
    "watch": "npm run watch -ws",
    "clean": "rimraf packages/**/out",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "npm run package -ws",
    "package:prerelease": "npm run package:prerelease -ws",
    "bump:all": "node scripts/bump-all-versions.js",
    "changeset": "changeset",
    "changeset:generate": "node scripts/generate-changeset.js",
    "version": "changeset version"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/vscode": "^1.109.0",
    "@types/vscode-webview": "^1.57.5",
    "esbuild": "^0.21.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "rimraf": "^5.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.55.0",
    "vitest": "^3.1.1",
    "vscode-test": "^1.6.1"
  }
}
