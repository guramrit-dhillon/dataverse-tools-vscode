{
  "name": "dataverse-tools-pack",
  "repository": {
    "type": "git",
    "url": "https://github.com/guramrit-dhillon/dataverse-tools-vscode.git"
  },
  "license": "MIT",
  "displayName": "Dataverse Tools",
  "description": "Complete toolkit for Dynamics 365 / Power Platform plugin development — deploy, register, trace, decompile, and query Dataverse from VS Code.",
  "version": "0.3.0",
  "publisher": "gdhillon",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Extension Packs"
  ],
  "keywords": [
    "dataverse",
    "power platform",
    "dynamics 365",
    "plugin",
    "crm"
  ],
  "icon": "resources/icon.png",
  "extensionPack": [
    "gdhillon.dataverse-environments",
    "gdhillon.dataverse-plugin-trace-viewer",
    "gdhillon.fetchxml-builder",
    "gdhillon.dataverse-query-analyzer",
    "gdhillon.dataverse-workflows",
    "gdhillon.dataverse-web-resources"
  ],
  "scripts": {
    "build": "echo 'No build step for extension pack'",
    "package": "npx @vscode/vsce package --no-dependencies -o out/",
    "package:prerelease": "npx @vscode/vsce package --no-dependencies --pre-release -o out/"
  }
}
