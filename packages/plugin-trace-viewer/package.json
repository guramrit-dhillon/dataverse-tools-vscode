{
  "name": "dataverse-plugin-trace-viewer",
  "displayName": "Dataverse Tools: Trace Viewer",
  "description": "View and analyze trace logs for Dataverse plugins in VS Code",
  "version": "0.1.0",
  "publisher": "gdhillon",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "dataverse",
    "power platform",
    "dynamics 365",
    "plugin",
    "crm"
  ],
  "extensionDependencies": [
    "gdhillon.dataverse-environments"
  ],
  "activationEvents": [
    "workspaceContains:**/*.csproj"
  ],
  "main": "./out/extension.js",
  "icon": "resources/icon.png",
  "contributes": {
    "commands": [
      {
        "command": "dataverse-tools.traceLog",
        "title": "View Trace Logs…",
        "category": "Dataverse Tools: Trace Viewer",
        "icon": "$(output)"
      },
      {
        "command": "dataverse-tools.traceLog.changeEnvironment",
        "title": "Change Environment",
        "category": "Dataverse Tools: Trace Viewer",
        "icon": "$(plug)"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "dataverse-tools.traceLog",
          "when": "view == dataverse-tools.environments && viewItem == environment",
          "group": "2_tools@1"
        }
      ],
      "editor/title/context": [
        {
          "command": "dataverse-tools.traceLog.changeEnvironment",
          "when": "activeWebviewPanelId == dataverse-tools.traceLog"
        }
      ]
    }
  },
  "scripts": {
    "build": "node ../../scripts/build-extension.js --production",
    "watch": "node ../../scripts/build-extension.js --watch"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.109.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.21.0",
    "eslint": "^9.39.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.55.0"
  }
}
