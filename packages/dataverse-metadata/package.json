{
  "name": "dataverse-metadata",
  "repository": {
    "type": "git",
    "url": "https://github.com/guramrit-dhillon/dataverse-tools-vscode.git"
  },
  "license": "MIT",
  "displayName": "Dataverse Tools: Metadata",
  "description": "Contributes metadata providers (entities, etc.) to the Dataverse Explorer",
  "version": "0.2.1",
  "publisher": "gdhillon",
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "dataverse",
    "power platform",
    "dynamics 365",
    "plugin",
    "crm"
  ],
  "extensionDependencies": [
    "gdhillon.dataverse-environments"
  ],
  "activationEvents": [
    "workspaceContains:**/*.csproj",
    "onView:dataverse-tools.explorer"
  ],
  "main": "./out/extension.js",
  "icon": "resources/icon.png",
  "scripts": {
    "build": "node ../../scripts/build-extension.js --production",
    "watch": "node ../../scripts/build-extension.js --watch",
    "package": "vsce package --out ../../dataverse-metadata.vsix",
    "package:prerelease": "vsce package --pre-release --out ../../dataverse-metadata.vsix"
  },
  "dependencies": {
    "core-dataverse": "0.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.21.0",
    "eslint": "^9.39.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.55.0"
  }
}
